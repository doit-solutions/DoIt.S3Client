{
    "name": "do IT S3 Client",
    "dockerComposeFile": [ "../docker-compose.yml" ],
    "service": "dev",
    "workspaceFolder": "/workspace/",
    "customizations": {
        "vscode": {
            "settings": {
                "chat.disableAIFeatures": true,
                "telemetry.feedback.enabled": false,
                "telemetry.telemetryLevel": "off",
                "dotnetAcquisitionExtension.enableTelemetry": false,
                "gitlens.telemetry.enabled": false,
                "editor.fontFamily": "'Cascadia Code NF', 'Cascadia Code PL', 'Cascadia Code', Consolas, 'Courier New', monospace",
                "editor.fontLigatures": true,
                "editor.formatOnSave": true,
                "dotnet.preferRuntimeFromSDK": true,
                "files.exclude": {
                    "**/.git": true,
                    "**/bin": true,
                    "**/obj": true
                },
                "search.exclude": {
                    "**/.git": true,
                    "**/bin": true,
                    "**/obj": true
                }
            },
            "extensions": [
                "dotjoshjohnson.xml",
                "eamodio.gitlens",
                "editorconfig.editorconfig",
                "ms-dotnettools.csdevkit"
            ]
        }
    },
    "postCreateCommand": "git config --global --add safe.directory '/workspace' && dotnet tool install --global dotnet-outdated-tool"
}
